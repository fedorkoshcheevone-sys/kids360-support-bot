# Скопируйте этот файл в .env и подставьте реальный ключ.
# .env в .gitignore и НИКОГДА не попадает в git.

OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o

# Необязательно: для OpenAI-совместимых роутеров (напр. Polza.ai).
# Если задано — клиент ходит по этому адресу вместо api.openai.com,
# а ключ тогда от роутера (напр. pza-...), и MODEL — в формате роутера.
# OPENAI_BASE_URL=https://polza.ai/api/v1
